{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cuer",
  "version": "0.1.0",
  "identifier": "com.guidouil.cuer",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../dist-desktop"
  },
  "bundle": {
    "resources": {
      "../dist-desktop-resources/backend/": "backend/"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cuer",
        "width": 1320,
        "height": 880,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  }
}
