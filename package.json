{
  "name": "cuer",
  "version": "0.1.0",
  "description": "Local-first agentic development orchestrator for the terminal.",
  "license": "MIT",
  "author": "Guidouil",
  "type": "module",
  "bin": {
    "cuer": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "planner.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/index.ts",
    "install:local": "npm install --global --prefix \"${CUER_NPM_PREFIX:-$HOME/.local}\" .",
    "prepare": "npm run build",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
