{
  "name": "cuer",
  "version": "0.1.0",
  "description": "Local-first agentic development orchestrator for the terminal.",
  "license": "MIT",
  "author": "Guidouil",
  "type": "module",
  "bin": {
    "cuer": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "prompts/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "desktop:bridge": "node scripts/buildDesktopBridge.mjs",
    "desktop:build": "vite build && npm run desktop:bridge",
    "desktop:dev": "vite",
    "dev": "tsx src/cli/index.ts",
    "install:local": "npm install --global --prefix \"${CUER_NPM_PREFIX:-$HOME/.local}\" .",
    "prepare": "npm run build",
    "start": "node dist/cli/index.js",
    "test": "tsc --noEmit -p tsconfig.test.json && node --import tsx --test test/*.test.ts",
    "tauri:build": "npm run build && tauri build",
    "tauri:dev": "npm run build && npm run desktop:bridge && tauri dev",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "beercss": "^4.0.20",
    "better-sqlite3": "^12.9.0",
    "material-dynamic-colors": "^1.1.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
